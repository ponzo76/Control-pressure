<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <title>Monitoraggio Pressione</title>
  <style>
    body { font-family: system-ui, sans-serif; margin: 16px; }
    input, button, textarea { font-size: 14px; margin: 4px 0; }
    table { border-collapse: collapse; width: 100%; margin-top: 12px; }
    th, td { border: 1px solid #ccc; padding: 4px; font-size: 13px; text-align: center; }
    th { background: #f0f0f0; }
  </style>
</head>
<body>
  <h2>Monitoraggio pressione</h2>

  <div>
    <label>Data/ora:
      <input type="datetime-local" id="dt">
    </label><br>
    <label>Sistolica:
      <input type="number" id="sys">
    </label><br>
    <label>Diastolica:
      <input type="number" id="dia">
    </label><br>
    <label>Battiti:
      <input type="number" id="hr">
    </label><br>
    <label>Note:
      <input type="text" id="note">
    </label><br>
    <button onclick="addRow()">Aggiungi</button>
    <button onclick="exportTxt()">Esporta TXT</button>
  </div>

  <table id="tbl">
    <thead>
      <tr>
        <th>#</th>
        <th>Data/ora</th>
        <th>Sistolica</th>
        <th>Diastolica</th>
        <th>Battiti</th>
        <th>Note</th>
      </tr>
    </thead>
    <tbody></tbody>
  </table>

  <script>
    let rows = [];

    function addRow() {
      const dt = document.getElementById('dt').value;
      const sys = document.getElementById('sys').value;
      const dia = document.getElementById('dia').value;
      const hr  = document.getElementById('hr').value;
      const note = document.getElementById('note').value;

      if (!dt || !sys || !dia) {
        alert("Data/ora, sistolica e diastolica sono obbligatorie.");
        return;
      }

      const row = { dt, sys, dia, hr, note };
      rows.push(row);
      renderTable();
    }

    function renderTable() {
      const tbody = document.querySelector('#tbl tbody');
      tbody.innerHTML = '';
      rows.forEach((r, i) => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>${i + 1}</td>
          <td>${r.dt}</td>
          <td>${r.sys}</td>
          <td>${r.dia}</td>
          <td>${r.hr || ''}</td>
          <td>${r.note || ''}</td>
        `;
        tbody.appendChild(tr);
      });
    }

    function exportTxt() {
      if (rows.length === 0) {
        alert("Nessun dato da esportare.");
        return;
      }
      let lines = ["# Monitoraggio pressione", ""];
      rows.forEach((r, i) => {
        lines.push(
          `${i + 1}) ${r.dt} | ${r.sys}/${r.dia} mmHg | HR: ${r.hr || '-'} | Note: ${r.note || ''}`
        );
      });
      const blob = new Blob([lines.join("\n")], { type: "text/plain;charset=utf-8" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = "pressione.txt";
      a.click();
      URL.revokeObjectURL(url);
    }
  </script>
</body>
</html>

